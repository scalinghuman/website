---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="RT Library Support"
  description="Support for the RT Library co-op catalog app."
  path="/apps/rt-library/support"
>
  <article class="container prose">
    <header class="page-header">
      <p class="page-header__kicker">RT Library · Help</p>
      <h1 class="page-header__title">RT Library Support</h1>
      <p class="page-header__lead">
        RT Library helps co-op shareholders browse and search the shared library
        room at Riviera Towers West New York, a private co-op building.
      </p>
    </header>

    <h2>Current Features</h2>
    <ul>
      <li>Search books by title, author, or genre.</li>
      <li>Browse books by genre.</li>
      <li>
        View book details generated from shelf photos, OCR, and public metadata
        lookup.
      </li>
    </ul>

    <h2>Coming Soon</h2>
    <ul>
      <li>Co-op shareholder book requests.</li>
      <li>Book donation photo flow.</li>
      <li>Shared availability updates.</li>
    </ul>

    <h2>Feedback</h2>
    <p>
      Feedback, feature requests, and catalog corrections are welcome.
    </p>
    <p>
      Email:
      <a href="mailto:srikantha.ballani@gmail.com"
        >srikantha.ballani@gmail.com</a
      >
    </p>

    <div class="links-row">
      <a href="/apps/rt-library/privacy">Privacy Policy</a>
      <a href="/apps/rt-library">RT Library</a>
      <a href="/">Home</a>
    </div>
  </article>
</BaseLayout>
