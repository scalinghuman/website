---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Path for canonical URL, e.g. /privacy.html */
  path?: string;
}

const {
  title,
  description = "Free hardware and AI tools under the Scaling Human name — open experiments and apps that explore human perception, memory, judgment, and capability.",
  path = Astro.url.pathname,
} = Astro.props;

const site = Astro.site ?? new URL("https://scalinghuman.ai");
const canonical = new URL(path, site).href;
const pageTitle =
  title === "Scaling Human" ? "Scaling Human" : `${title} · Scaling Human`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Scaling Human" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
