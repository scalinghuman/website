---
/**
 * Cloudflare Web Analytics (privacy-first beacon).
 * Set PUBLIC_CF_BEACON_TOKEN at build time (GitHub Actions secret or .env).
 * Hosting stays on GitHub Pages — analytics is a script only.
 * https://developers.cloudflare.com/web-analytics/get-started/
 */
const token = import.meta.env.PUBLIC_CF_BEACON_TOKEN as string | undefined;
---

{
  token ? (
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={JSON.stringify({ token })}
    />
  ) : null
}
